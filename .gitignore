# Ignore node modules
node_modules/
npm-debug.log
yarn-error.log

# Ignore build outputs
build/
dist/
.gradle/
*.apk
*.aab

# Ignore OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Ignore IDE
.vscode/
.idea/
*.swp
*.sublime-project

# Ignore environment
.env
.env.local

# Ignore logs
*.log
logs/

# Ignore cache
.cache/
.npm/

# Keep only essential FlashBrowser files
# All other binaries/libraries will be in Docker
FlashBrowser-linux-x64/locales/
FlashBrowser-linux-x64/swiftshader/

# Allow required runtime files for FlashBrowser
!FlashBrowser-linux-x64/FlashBrowser
!FlashBrowser-linux-x64/libEGL.so
!FlashBrowser-linux-x64/libffmpeg.so
!FlashBrowser-linux-x64/libGLESv2.so
!FlashBrowser-linux-x64/libvk_swiftshader.so
!FlashBrowser-linux-x64/libvulkan.so
!FlashBrowser-linux-x64/icudtl.dat
!FlashBrowser-linux-x64/resources.pak
!FlashBrowser-linux-x64/snapshot_blob.bin
!FlashBrowser-linux-x64/v8_context_snapshot.bin
!FlashBrowser-linux-x64/vk_swiftshader_icd.json
!FlashBrowser-linux-x64/chrome_100_percent.pak
!FlashBrowser-linux-x64/chrome_200_percent.pak

# Ignore other runtime binaries and large build artifacts
FlashBrowser-linux-x64/*.dll
FlashBrowser-linux-x64/*.bin
FlashBrowser-linux-x64/*.exe
