    "react-native-reanimated": "^3.5.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "babel-jest": "^29.5.0",
    "jest": "^29.5.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "eslint": "^8.43.0"
  },
  "jest": {
    "preset": "react-native"
